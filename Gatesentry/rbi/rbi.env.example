# ============================================================================
#  RBI single source of truth. Compose, the controller, and the in-container
#  entrypoint all read these. Change a value HERE only.
# ============================================================================

# ---- NEKO VERSION BLOCK — the ONE place to reconcile with your real image ----
# Targeting neko **v3** (env names NEKO_WEBRTC_* / NEKO_MEMBER_*), CHROMIUM build.
# Chromium renders under arm64 QEMU emulation; the google-chrome build SIGTRAPs.
# This is the BASE image for `docker build` of RBI_IMAGE (below). Prod on x86-64
# may pin the official ghcr.io/m1k1o/neko/chromium:3.0.4 (same layout, same policy).
NEKO_IMAGE=arxndevv/glass-fence-chromium:latest
NEKO_MAJOR=3
NEKO_SUPERVISORD_BIN=/usr/bin/supervisord
NEKO_SUPERVISORD_CONF=/etc/neko/supervisord.conf
NEKO_DESKTOP_SCREEN=1920x1080@30
NEKO_MEMBER_PROVIDER=multiuser
NEKO_SESSION_IMPLICIT_HOSTING=true
NEKO_WEBRTC_ICELITE=false

# ---- topology / ports (shared by compose + controller + firewall) ----
# Built from rbi-chrome/Dockerfile (neko-chromium + nftables + URL lockdown + CA trust).
RBI_IMAGE=rbi-chrome-neko:latest
RBI_ISOLATED_NETWORK=rbi_gs-isolated
RBI_PROXY_HOST=gatesentry
RBI_EGRESS_PORT=3129
RBI_CLIENT_PORT=8080
RBI_VIEWER_PORT=8081
RBI_TURN_HOST=coturn
RBI_TURN_PORT=3478
RBI_IDLE_TIMEOUT=120s

# ---- coturn relay range — MUST match: turnserver flags + compose publish ----
COTURN_RELAY_MIN=49152
COTURN_RELAY_MAX=49252

# ---- neko local media (EPR) source range ----
NEKO_EPR_MIN=52000
NEKO_EPR_MAX=52100

# ---- secrets / host specifics (local dev values) ----
PUBLIC_IP=127.0.0.1
TURN_SECRET=REPLACE_WITH_RANDOM_HEX_SECRET
TURN_REALM=rbi.local
